local Players = game:GetService("Players")
local VirtualInputManager = game:GetService("VirtualInputManager")

local player = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")
local running = false

local function clickAt(x, y)
	VirtualInputManager:SendMouseMoveEvent(x, y, game)
	task.wait(0.05)
	VirtualInputManager:SendMouseButtonEvent(x, y, 0, true, game, 1)
	task.wait(0.15)
	VirtualInputManager:SendMouseButtonEvent(x, y, 0, false, game, 1)
	task.wait(0.15)
end

local function moveMouseTo(x, y)
	VirtualInputManager:SendMouseMoveEvent(x, y, game)
	task.wait(0.1)
end

local function pressKey(keyCode)
	VirtualInputManager:SendKeyEvent(true, keyCode, false, game)
	task.wait(0.1)
	VirtualInputManager:SendKeyEvent(false, keyCode, false, game)
	task.wait(0.1)
end

local function clickButton(button)
	local pos = button.AbsolutePosition
	local size = button.AbsoluteSize
	local x = math.floor(pos.X + size.X / 2)
	local y = math.floor(pos.Y + size.Y / 2)
	clickAt(x, y)
end

local function getRootPart()
	local char = player.Character
	if not char then return nil end
	return char:FindFirstChild("HumanoidRootPart")
end

local function isAreaEmpty(areaPart)
	local areaPos = areaPart.Position
	for _, otherPlayer in ipairs(Players:GetPlayers()) do
		if otherPlayer ~= player then
			local otherChar = otherPlayer.Character
			if otherChar then
				local otherRoot = otherChar:FindFirstChild("HumanoidRootPart")
				if otherRoot then
					local dist = (otherRoot.Position - areaPos).Magnitude
					if dist < 50 then
						return false
					end
				end
			end
		end
	end
	return true
end

local function findEmptyToiletArea(lifts)
	local toiletAreas = {}
	for _, lift in ipairs(lifts:GetChildren()) do
		if string.match(lift.Name, "^ToiletHQ") then
			local area = lift:FindFirstChild("Area")
			if area then
				table.insert(toiletAreas, area)
			end
		end
	end
	for _, area in ipairs(toiletAreas) do
		if isAreaEmpty(area) then
			return area
		end
	end
	return nil
end

local function tryWorld1()
	local lifts = workspace:FindFirstChild("Lifts")
	if not lifts then return end

	while workspace:FindFirstChild("Lifts") do

		local rootPart = getRootPart()
		if not rootPart then
			task.wait(1)
			continue
		end

		local targetArea = findEmptyToiletArea(lifts)

		if not targetArea then
			task.wait(2)
			continue
		end

		rootPart.CFrame = targetArea.CFrame + Vector3.new(0, 3, 0)
		task.wait(1)

		if not isAreaEmpty(targetArea) then
			task.wait(1)
			continue
		end

		local lobbyGui = playerGui:FindFirstChild("Lobby")
		if not lobbyGui then
			task.wait(1)
			continue
		end

		local queueFrame = lobbyGui:FindFirstChild("QueueFrame")
		if not queueFrame then
			task.wait(1)
			continue
		end

		local startButton = queueFrame:FindFirstChild("Start")
		if not startButton then
			task.wait(1)
			continue
		end

		local elapsed = 0
		local teleported = false

		while elapsed < 5 do
			if not workspace:FindFirstChild("Lifts") then
				teleported = true
				break
			end
			clickButton(startButton)
			task.wait(0.3)
			elapsed = elapsed + 0.3
		end

		if teleported then
			break
		end

		if not workspace:FindFirstChild("Lifts") then
			break
		end
	end

	if not workspace:FindFirstChild("Lifts") then
		task.wait(2)
		clickAt(767, 690)
	end
end

local function runMacro()
	if running then return end
	running = true

	local rootPart = getRootPart()
	if not rootPart then
		running = false
		return
	end

	task.wait(1.5)

	if workspace:FindFirstChild("Lifts") then

		tryWorld1()

	else

		clickAt(823, 122)
		task.wait(0.5)

		rootPart = getRootPart()
		if rootPart then
			rootPart.CFrame = CFrame.new(
				112.189713, 18.0619602, 192.314941,
				1, 0, 0,
				0, 1, 0,
				0, 0, 1
			)
		end
		task.wait(1.5)

		pressKey(Enum.KeyCode.Five)
		task.wait(0.5)

		clickAt(378, 393)

		task.wait(25)

		moveMouseTo(1120, 428)
		task.wait(0.3)
		pressKey(Enum.KeyCode.Five)
		task.wait(0.3)
		clickAt(1120, 428)

		task.wait(41)

		clickAt(378, 393)

		task.wait(4)

		clickAt(98, 496)

		task.wait(35)

		clickAt(98, 496)

		task.wait(39)

		clickAt(98, 496)

	end

	running = false
end

local function onCharacterAdded(character)
	running = false
	task.wait(1)
	task.spawn(runMacro)
end

player.CharacterAdded:Connect(onCharacterAdded)

if player.Character then
	task.spawn(runMacro)
end
